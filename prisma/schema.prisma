// ============================================
// ✅ EXIT INTELLIGENCE v1.0
// ============================================

// MODELO EXIT 1: ExitRecord
model ExitRecord {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  departmentId  String   @map("department_id")

  // ═══════════════════════════════════════════════════
  // VÍNCULO AL SISTEMA EXISTENTE (1:1 con Participant)
  // ═══════════════════════════════════════════════════
  participantId String   @unique @map("participant_id")
  nationalId    String   @map("national_id")

  // ═══════════════════════════════════════════════════
  // DATOS EXCLUSIVOS DE EXIT
  // ═══════════════════════════════════════════════════
  exitDate      DateTime @map("exit_date") @db.Date
  exitReason    String?  @map("exit_reason") // voluntary|termination|contract_end|retirement|other

  // ═══════════════════════════════════════════════════
  // EIS - EXIT INTELLIGENCE SCORE (calculado)
  // Fórmula: 20%P1 + 25%P4 + 20%P5 + 25%P6 + 10%P7
  // ═══════════════════════════════════════════════════
  eis               Float?   @map("eis")
  eisClassification String?  @map("eis_classification") // healthy|neutral|problematic|toxic

  // ═══════════════════════════════════════════════════
  // P2 + P3: CAUSAS RAÍZ (factores cualitativos)
  // ═══════════════════════════════════════════════════
  exitFactors       String[] @map("exit_factors")        // Multi-select P2
  exitFactorsDetail Json?    @map("exit_factors_detail") // Matrix P3 {factor: score}
  exitFactorsAvg    Float?   @map("exit_factors_avg")    // Promedio severidad

  // ═══════════════════════════════════════════════════
  // CORRELACIÓN ONBOARDING (detectada por nationalId)
  // ═══════════════════════════════════════════════════
  hadOnboarding           Boolean  @default(false) @map("had_onboarding")
  onboardingJourneyId     String?  @map("onboarding_journey_id")
  onboardingEXOScore      Float?   @map("onboarding_exo_score")
  onboardingAlertsCount   Int      @default(0) @map("onboarding_alerts_count")
  onboardingIgnoredAlerts Int      @default(0) @map("onboarding_ignored_alerts")
  onboardingManagedAlerts Int      @default(0) @map("onboarding_managed_alerts")
  tenureMonths            Int?     @map("tenure_months")

  // ═══════════════════════════════════════════════════
  // RED FLAGS (detección automática)
  // ═══════════════════════════════════════════════════
  hasLeyKarinAlert        Boolean  @default(false) @map("has_ley_karin_alert")

  // ═══════════════════════════════════════════════════
  // CLASIFICACIÓN DE TALENTO (RRHH al registrar salida)
  // ═══════════════════════════════════════════════════
  talentClassification    String?  @map("talent_classification")
  
  // ═══════════════════════════════════════════════════
  // TIMESTAMPS
  // ═══════════════════════════════════════════════════
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  // ═══════════════════════════════════════════════════
  // RELACIONES
  // ═══════════════════════════════════════════════════
  participant   Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  department    Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  alerts        ExitAlert[]

  // ═══════════════════════════════════════════════════
  // ÍNDICES OPTIMIZADOS
  // ═══════════════════════════════════════════════════
  @@index([accountId, exitDate], map: "idx_exit_records_account_date")
  @@index([departmentId, exitDate], map: "idx_exit_records_department_date")
  @@index([nationalId], map: "idx_exit_records_national_id")
  @@index([eis], map: "idx_exit_records_eis")
  @@index([eisClassification], map: "idx_exit_records_classification")
  @@index([hasLeyKarinAlert], map: "idx_exit_records_ley_karin")
  @@map("exit_records")
}

// MODELO EXIT 2: ExitAlert (alertas departamentales, no individuales)
model ExitAlert {
  id            String    @id @default(cuid())
  exitRecordId  String?   @map("exit_record_id") // Opcional: puede ser alerta de patrón
  accountId     String    @map("account_id")
  departmentId  String    @map("department_id")

  // ═══════════════════════════════════════════════════
  // TIPO DE ALERTA
  // ═══════════════════════════════════════════════════
  alertType     String    @map("alert_type")
  // Tipos válidos:
  // - ley_karin: P6 < 2.5 (ambiente no seguro)
  // - liderazgo_concentracion: 3+ exits mismo factor liderazgo
  // - nps_critico: eNPS < -30 en departamento
  // - toxic_exit_detected: EIS < 40 individual
  // - department_exit_pattern: Patrón normalizado departamental
  // - onboarding_exit_correlation: Correlación alertas ignoradas

  severity      String    // critical|high|medium|low
  title         String
  description   String

  // ═══════════════════════════════════════════════════
  // CONTEXTO POR TIPO (campos dinámicos)
  // ═══════════════════════════════════════════════════
  triggerScore    Float?    @map("trigger_score")   // Score que disparó alerta
  exitCount       Int?      @map("exit_count")      // Exits involucrados en patrón
  triggerFactor   String?   @map("trigger_factor")  // Factor P2/P3 predominante
  avgScore        Float?    @map("avg_score")       // Score promedio del patrón
  enpsValue       Float?    @map("enps_value")      // eNPS del departamento
  periodStart     DateTime? @map("period_start")    // Inicio período análisis
  periodEnd       DateTime? @map("period_end")      // Fin período análisis

  // ═══════════════════════════════════════════════════
  // GESTIÓN (patrón idéntico a JourneyAlert)
  // ═══════════════════════════════════════════════════
  status          String    @default("pending") // pending|acknowledged|resolved|dismissed
  acknowledgedAt  DateTime? @map("acknowledged_at")
  acknowledgedBy  String?   @map("acknowledged_by")
  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?   @map("resolved_by")
  resolutionNotes String?   @map("resolution_notes") @db.Text

  // ═══════════════════════════════════════════════════
  // SLA (trackeable pero sin presión urgente como Onboarding)
  // ═══════════════════════════════════════════════════
  slaHours        Int?      @map("sla_hours")   // Sugerido, no obligatorio
  dueDate         DateTime? @map("due_date")
  slaStatus       String?   @map("sla_status")  // on_track|at_risk|breached|null

  // ═══════════════════════════════════════════════════
  // TIMESTAMPS
  // ═══════════════════════════════════════════════════
  createdAt       DateTime  @default(now()) @map("created_at")

  // ═══════════════════════════════════════════════════
  // RELACIONES
  // ═══════════════════════════════════════════════════
  exitRecord      ExitRecord? @relation(fields: [exitRecordId], references: [id], onDelete: Cascade)
  department      Department  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  account         Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // ═══════════════════════════════════════════════════
  // ÍNDICES OPTIMIZADOS
  // ═══════════════════════════════════════════════════
  @@index([accountId, status], map: "idx_exit_alerts_account_status")
  @@index([departmentId, status], map: "idx_exit_alerts_department_status")
  @@index([alertType, status], map: "idx_exit_alerts_type_status")
  @@index([severity, status], map: "idx_exit_alerts_severity_status")
  @@index([createdAt], map: "idx_exit_alerts_created")
  @@map("exit_alerts")
}

// MODELO EXIT 3: DepartmentExitInsight (agregación mensual LENTE 1)
model DepartmentExitInsight {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  departmentId  String   @map("department_id")

  // ═══════════════════════════════════════════════════
  // PERÍODO (patrón FocalizaHR)
  // ═══════════════════════════════════════════════════
  period        String   // "2025-12", "2025-Q4", "2025"
  periodType    String   @default("monthly") @map("period_type") // monthly|quarterly|yearly
  periodStart   DateTime @map("period_start") @db.Date
  periodEnd     DateTime @map("period_end") @db.Date

  // ═══════════════════════════════════════════════════
  // MÉTRICAS BÁSICAS
  // ═══════════════════════════════════════════════════
  totalExits        Int @default(0) @map("total_exits")
  voluntaryExits    Int @default(0) @map("voluntary_exits")
  involuntaryExits  Int @default(0) @map("involuntary_exits")
  surveysCompleted  Int @default(0) @map("surveys_completed")

  // ═══════════════════════════════════════════════════
  // SCORES PROMEDIO (de ExitRecord)
  // ═══════════════════════════════════════════════════
  avgSatisfaction   Float? @map("avg_satisfaction")   // P1
  avgFactorsScore   Float? @map("avg_factors_score")  // P3 promedio
  avgLeadership     Float? @map("avg_leadership")     // P4
  avgDevelopment    Float? @map("avg_development")    // P5
  avgSafety         Float? @map("avg_safety")         // P6 (Ley Karin)
  avgAutonomy       Float? @map("avg_autonomy")       // P7
  avgNPS            Float? @map("avg_nps")            // P8 (0-10)

  // ═══════════════════════════════════════════════════
  // EIS AGREGADO
  // ═══════════════════════════════════════════════════
  avgEIS            Float? @map("avg_eis")
  eisTrend          Float? @map("eis_trend") // vs período anterior

  // ═══════════════════════════════════════════════════
  // eNPS DEPARTAMENTAL
  // ═══════════════════════════════════════════════════
  enps              Float? @map("enps") // -100 a +100
  promoters         Int    @default(0)  // 9-10
  passives          Int    @default(0)  // 7-8
  detractors        Int    @default(0)  // 0-6

  // ═══════════════════════════════════════════════════
  // TOP FACTORES P2+P3 (causas raíz agregadas)
  // ═══════════════════════════════════════════════════
  topExitFactors    Json?  @map("top_exit_factors")
  // Estructura: [{ factor: string, mentions: number, mentionRate: number, avgSeverity: number }]

  // ═══════════════════════════════════════════════════
  // CORRELACIÓN ONBOARDING (ÚNICO DIFERENCIADOR)
  // ═══════════════════════════════════════════════════
  exitsWithOnboarding       Int    @default(0) @map("exits_with_onboarding")
  exitsWithOnboardingAlerts Int    @default(0) @map("exits_with_onboarding_alerts")
  exitsWithIgnoredAlerts    Int    @default(0) @map("exits_with_ignored_alerts")
  avgOnboardingEXOOfExits   Float? @map("avg_onboarding_exo_of_exits")
  conservationIndex         Float? @map("conservation_index")      // % que recibió alerta y NO se fue
  alertPredictionRate       Float? @map("alert_prediction_rate")   // % exits que tuvieron alerta previa

  // ═══════════════════════════════════════════════════
  // ALERTAS GENERADAS
  // ═══════════════════════════════════════════════════
  alertsGenerated           Int @default(0) @map("alerts_generated")

  // ═══════════════════════════════════════════════════
  // TIMESTAMPS
  // ═══════════════════════════════════════════════════
  calculatedAt              DateTime @default(now()) @map("calculated_at")

  // ═══════════════════════════════════════════════════
  // RELACIONES
  // ═══════════════════════════════════════════════════
  account     Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  // ═══════════════════════════════════════════════════
  // CONSTRAINTS E ÍNDICES
  // ═══════════════════════════════════════════════════
  @@unique([departmentId, period, periodType])
  @@index([accountId], map: "idx_dept_exit_insights_account")
  @@index([departmentId], map: "idx_dept_exit_insights_department")
  @@index([periodStart, periodEnd], map: "idx_dept_exit_insights_period")
  @@index([avgEIS], map: "idx_dept_exit_insights_eis")
  @@index([avgSafety], map: "idx_dept_exit_insights_safety")
  @@map("department_exit_insights")
}

// ════════════════════════════════════════════════════════════════════════════
// EMPLOYEE MASTER + PERFORMANCE EVALUATION
// Fecha: Enero 2025
// ════════════════════════════════════════════════════════════════════════════

// ════════════════════════════════════════════════════════════════════════════
// EMPLOYEE - Nómina Permanente
// ════════════════════════════════════════════════════════════════════════════

model Employee {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  // Identificadores
  nationalId     String  @map("national_id")       // RUT único por account
  employeeNumber String? @map("employee_number")   // Código interno (EMP-001)

  // Datos personales
  fullName      String  @map("full_name")
  preferredName String? @map("preferred_name")
  email         String?
  phoneNumber   String? @map("phone_number")

  // Datos organizacionales
  departmentId   String  @map("department_id")
  position       String?
  jobTitle       String? @map("job_title")
  seniorityLevel String? @map("seniority_level")  // junior|mid|senior|lead|executive
  employmentType String? @map("employment_type")  // full-time|part-time|contractor
  managerLevel   Int?    @map("manager_level")    // 1=CEO, 2=Dir, 3=Ger, 4=Jefe, 5=IC
  costCenter     String? @map("cost_center")

  // ═══════════════════════════════════════════════════
  // 🆕 CLASIFICACIÓN CARGO (calculado por PositionAdapter)
  // ═══════════════════════════════════════════════════
  standardJobLevel String?   @map("standard_job_level")
  // Valores: 'gerente_director' | 'subgerente_subdirector' | 'jefe' |
  //          'supervisor_coordinador' | 'profesional_analista' |
  //          'asistente_otros' | 'operativo_auxiliar'

  acotadoGroup     String?   @map("acotado_group")
  // Valores: 'alta_gerencia' | 'mandos_medios' | 'profesionales' | 'base_operativa'

  jobLevelMappedAt DateTime? @map("job_level_mapped_at")
  jobLevelMethod   String?   @map("job_level_method")  // 'auto' | 'manual'

  // ═══════════════════════════════════════════════════
  // 🆕 CLASIFICACIÓN DESEMPEÑO (derivado de standardJobLevel)
  // ═══════════════════════════════════════════════════
  performanceTrack String?   @map("performance_track")
  // Valores: 'COLABORADOR' | 'MANAGER' | 'EJECUTIVO'

  trackMappedAt    DateTime? @map("track_mapped_at")
  trackHasAnomaly  Boolean   @default(false) @map("track_has_anomaly")
  // true si hay inconsistencia entre track derivado y estructura real

  // Jerarquía (self-reference)
  managerId String? @map("manager_id")

  // Estado y ciclo de vida
  status            EmployeeStatus @default(ACTIVE)
  isActive          Boolean        @default(true) @map("is_active")
  hireDate          DateTime       @map("hire_date")
  terminatedAt      DateTime?      @map("terminated_at")
  terminationReason String?        @map("termination_reason")
  rehireDate        DateTime?      @map("rehire_date")
  tenureCount       Int            @default(1) @map("tenure_count")

  // Control de sincronización
  importSource        String?   @map("import_source")
  lastImportId        String?   @map("last_import_id")
  lastSeenInImport    DateTime? @map("last_seen_in_import")
  pendingReview       Boolean   @default(false) @map("pending_review")
  pendingReviewReason String?   @map("pending_review_reason")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  account       Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  department    Department       @relation(fields: [departmentId], references: [id])
  manager       Employee?        @relation("ManagerSubordinates", fields: [managerId], references: [id])
  directReports Employee[]       @relation("ManagerSubordinates")
  history       EmployeeHistory[]
  participants  Participant[]

  // Evaluaciones (se usarán en Performance)
  evaluationsAsEvaluatee EvaluationAssignment[] @relation("Evaluatee")
  evaluationsAsEvaluator EvaluationAssignment[] @relation("Evaluator")

  // Performance Classification
  performanceRatings     PerformanceRating[]

  // PDI (Plan de Desarrollo Individual)
  developmentPlans       DevelopmentPlan[] @relation("EmployeePDI")
  managedPDIs            DevelopmentPlan[] @relation("ManagerPDI")

  // Metas (Business Goals Engine)
  goals                  Goal[]

  // Sucesion Inteligente
  incumbentOfPositions   CriticalPosition[]      @relation("PositionIncumbent")
  successionCandidacies  SuccessionCandidate[]   @relation("SuccessionCandidateEmployee")
  backfillAssignments    SuccessionBackfillPlan[] @relation("BackfillEmployee")

  // Índices
  @@unique([accountId, nationalId], map: "idx_employees_account_national")
  @@index([accountId, status], map: "idx_employees_account_status")
  @@index([accountId, departmentId], map: "idx_employees_account_dept")
  @@index([managerId], map: "idx_employees_manager")
  @@index([accountId, pendingReview], map: "idx_employees_pending_review")
  @@index([accountId, standardJobLevel], map: "idx_employees_job_level")
  @@index([accountId, performanceTrack], map: "idx_employees_performance_track")
  @@index([accountId, trackHasAnomaly], map: "idx_employees_track_anomaly")
  @@map("employees")
}

// ════════════════════════════════════════════════════════════════════════════
// EMPLOYEE HISTORY - Auditoría por Campo
// ════════════════════════════════════════════════════════════════════════════

model EmployeeHistory {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  accountId  String   @map("account_id")

  // Tipo de cambio
  changeType EmployeeChangeType @map("change_type")

  // Campo específico que cambió
  fieldName String? @map("field_name")
  oldValue  String? @map("old_value")
  newValue  String? @map("new_value")

  // Snapshot al momento del cambio
  departmentId String? @map("department_id")
  managerId    String? @map("manager_id")
  position     String?

  // Origen del cambio
  changeSource  String?  @map("change_source")  // MANUAL|BULK_IMPORT|API
  importId      String?  @map("import_id")
  changedBy     String?  @map("changed_by")
  changeReason  String?  @map("change_reason")

  // Timestamp
  effectiveDate DateTime @default(now()) @map("effective_date")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relaciones
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Índices
  @@index([employeeId, effectiveDate], map: "idx_employee_history_emp_date")
  @@index([accountId, changeType], map: "idx_employee_history_account_type")
  @@index([importId], map: "idx_employee_history_import")
  @@map("employee_history")
}

// ════════════════════════════════════════════════════════════════════════════
// EMPLOYEE IMPORT - Log de Cargas
// ════════════════════════════════════════════════════════════════════════════

model EmployeeImport {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  // Configuración
  importMode EmployeeImportMode @map("import_mode")
  fileName   String?            @map("file_name")

  // Estadísticas
  totalInFile   Int @map("total_in_file")
  created       Int @default(0)
  updated       Int @default(0)
  rehired       Int @default(0)
  unchanged     Int @default(0)
  deactivated   Int @default(0)
  pendingReview Int @default(0) @map("pending_review")
  errors        Int @default(0)

  // Control de threshold
  missingCount      Int     @default(0) @map("missing_count")
  missingPercent    Float   @default(0) @map("missing_percent")
  thresholdExceeded Boolean @default(false) @map("threshold_exceeded")
  thresholdUsed     Float   @default(0.10) @map("threshold_used")

  // Estado
  status      EmployeeImportStatus @default(PENDING)
  startedAt   DateTime             @default(now()) @map("started_at")
  completedAt DateTime?            @map("completed_at")

  // Errores detallados
  errorLog Json? @map("error_log")

  // Usuario que ejecutó
  executedBy String? @map("executed_by")

  createdAt DateTime @default(now()) @map("created_at")

  // Relaciones
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Índices
  @@index([accountId, startedAt], map: "idx_employee_imports_account_date")
  @@index([status], map: "idx_employee_imports_status")
  @@map("employee_imports")
}

// ════════════════════════════════════════════════════════════════════════════
// PERFORMANCE CYCLE - Ciclo de Evaluación
// ════════════════════════════════════════════════════════════════════════════

model PerformanceCycle {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  // Vínculo con Campaign (para Questions)
  campaignId String?   @unique @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  // Identificación
  name        String
  description String?

  // Período
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  // Tipo de ciclo
  cycleType PerformanceCycleType @default(QUARTERLY) @map("cycle_type")

  // Configuración
  includesSelf    Boolean @default(false) @map("includes_self")
  includesManager Boolean @default(true) @map("includes_manager")
  includesPeer    Boolean @default(false) @map("includes_peer")
  includesUpward  Boolean @default(false) @map("includes_upward")

  anonymousResults Boolean @default(true) @map("anonymous_results")
  minSubordinates  Int     @default(3) @map("min_subordinates")

  // Estado
  status PerformanceCycleStatus @default(DRAFT)

  // ═══════════════════════════════════════════════════
  // COMPETENCY LIBRARY - Snapshot inmutable
  // Se congela al crear el ciclo - NO cambia aunque cliente edite biblioteca
  // ═══════════════════════════════════════════════════
  competencySnapshot Json? @map("competency_snapshot")
  // Estructura:
  // [
  //   {
  //     "code": "CORE-COMM",
  //     "name": "Comunicación Asertiva",
  //     "category": "CORE",
  //     "behaviors": ["Escucha activa", ...],
  //     "audienceRule": null
  //   },
  //   ...
  // ]

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  // Relaciones
  account     Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assignments EvaluationAssignment[]

  // Feedback Delivery (reportes individuales Performance)
  feedbackDeliveries FeedbackDeliveryConfirmation[] @relation("FeedbackDeliveryCycle")

  // ═══════════════════════════════════════════════════
  // PERFORMANCE CLASSIFICATION
  // ═══════════════════════════════════════════════════
  performanceRatings       PerformanceRating[]
  calibrationSessions      CalibrationSession[]
  developmentPlans         DevelopmentPlan[]

  // PONDERACIÓN OVERRIDE (Nivel 2: Override por Ciclo)
  // JSON: {self: 10, manager: 50, peer: 25, upward: 15} - casos especiales
  // Si null, usa config de cuenta o default FocalizaHR
  evaluatorWeightsOverride Json?   @map("evaluator_weights_override")

  // HYBRID SCORE: Pesos para cálculo Competencias + Metas (suman 100)
  competenciesWeight  Int      @default(70)   @map("competencies_weight")
  goalsWeight         Int      @default(30)   @map("goals_weight")
  includeGoals        Boolean  @default(true) @map("include_goals")

  // Índices
  @@index([accountId], map: "idx_performance_cycles_account")
  @@index([status], map: "idx_performance_cycles_status")
  @@index([startDate], map: "idx_performance_cycles_start")
  @@map("performance_cycles")
}

// ════════════════════════════════════════════════════════════════════════════
// EVALUATION ASSIGNMENT - Snapshot "X evalúa a Y"
// Datos CONGELADOS - NO cambian aunque Employee cambie
// ════════════════════════════════════════════════════════════════════════════

model EvaluationAssignment {
  id        String @id @default(cuid())
  accountId String @map("account_id")
  cycleId   String @map("cycle_id")

  // Referencias a Employee (para queries)
  evaluateeId String   @map("evaluatee_id")
  evaluatee   Employee @relation("Evaluatee", fields: [evaluateeId], references: [id])

  evaluatorId String   @map("evaluator_id")
  evaluator   Employee @relation("Evaluator", fields: [evaluatorId], references: [id])

  // SNAPSHOT CONGELADO
  snapshotDate DateTime @map("snapshot_date")

  // Datos del EVALUADO al momento del snapshot
  evaluateeName         String  @map("evaluatee_name")
  evaluateeNationalId   String  @map("evaluatee_national_id")
  evaluateeDepartmentId String  @map("evaluatee_department_id")
  evaluateeDepartment   String  @map("evaluatee_department")
  evaluateePosition     String? @map("evaluatee_position")

  // Datos del EVALUADOR al momento del snapshot
  evaluatorName         String  @map("evaluator_name")
  evaluatorNationalId   String  @map("evaluator_national_id")
  evaluatorDepartmentId String  @map("evaluator_department_id")
  evaluatorDepartment   String  @map("evaluator_department")

  // Tipo de evaluación
  evaluationType EvaluationType @map("evaluation_type")

  // ═══════════════════════════════════════════════════
  // COMPETENCY LIBRARY - Track del evaluado para filtrado
  // ═══════════════════════════════════════════════════
  evaluateePerformanceTrack String? @map("evaluatee_performance_track")
  // Valores: "COLABORADOR" | "MANAGER" | "EJECUTIVO"
  // Se congela al momento de crear el assignment (snapshot)

  // Vínculo con Participant (cuando se crea la encuesta)
  participant   Participant?

  // Estado y fechas
  status  EvaluationAssignmentStatus @default(PENDING)
  dueDate DateTime?                  @map("due_date")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  account Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cycle   PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  // Índices
  @@unique([cycleId, evaluatorId, evaluateeId, evaluationType], map: "idx_eval_assignment_unique")
  @@index([accountId], map: "idx_eval_assignment_account")
  @@index([evaluateeId], map: "idx_eval_assignment_evaluatee")
  @@index([evaluatorId], map: "idx_eval_assignment_evaluator")
  @@index([status], map: "idx_eval_assignment_status")
  @@index([cycleId], map: "idx_eval_assignment_cycle")
  @@map("evaluation_assignments")
}

// ════════════════════════════════════════════════════════════════════════════
// COMPETENCY LIBRARY - Biblioteca de Competencias por Account
// Patrón: Competency Library (SAP SuccessFactors, Lattice)
// Vínculo con Questions: Por código (competencyCode), NO por FK
// ════════════════════════════════════════════════════════════════════════════

model Competency {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  // ═══════════════════════════════════════════════════
  // IDENTIFICACIÓN
  // ═══════════════════════════════════════════════════
  code        String              // "CORE-COMM" - Vínculo con Question.competencyCode
  name        String              // "Comunicación Efectiva" - Personalizable
  description String?             // Descripción detallada

  // ═══════════════════════════════════════════════════
  // CLASIFICACIÓN
  // ═══════════════════════════════════════════════════
  category CompetencyCategory // CORE, LEADERSHIP, STRATEGIC, TECHNICAL

  // ═══════════════════════════════════════════════════
  // VÍNCULO SEMÁNTICO CON CLIMA
  // Permite correlación cruzada: Desempeño ↔ Clima
  // ═══════════════════════════════════════════════════
  dimensionCode    String? @map("dimension_code")    // "liderazgo", "ambiente", etc.
  subdimensionCode String? @map("subdimension_code") // "feedback", "comunicacion", etc.

  // ═══════════════════════════════════════════════════
  // COMPORTAMIENTOS OBSERVABLES
  // ═══════════════════════════════════════════════════
  behaviors Json? // ["Escucha activamente", "Adapta el mensaje", ...]

  // ═══════════════════════════════════════════════════
  // REGLA DE AUDIENCIA
  // ═══════════════════════════════════════════════════
  audienceRule Json? @map("audience_rule")
  // null = TODOS (Core)
  // {"minTrack": "MANAGER"} = Managers y Ejecutivos
  // {"minTrack": "EJECUTIVO"} = Solo Ejecutivos

  // ═══════════════════════════════════════════════════
  // CONFIGURACIÓN
  // ═══════════════════════════════════════════════════
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  // ═══════════════════════════════════════════════════
  // ORIGEN (para tracking)
  // ═══════════════════════════════════════════════════
  sourceTemplate String? @map("source_template") // "focalizahr-standard-v1"
  isCustom       Boolean @default(false) @map("is_custom")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([accountId, code], map: "unique_competency_code_per_account")
  @@index([accountId, isActive], map: "idx_competencies_account_active")
  @@index([category], map: "idx_competencies_category")
  @@index([dimensionCode], map: "idx_competencies_dimension")
  @@map("competencies")
}

// ════════════════════════════════════════════════════════════════════════════
// FEEDBACK DELIVERY CONFIRMATION - Auditoría entrega reportes individuales
// ════════════════════════════════════════════════════════════════════════════

model FeedbackDeliveryConfirmation {
  id               String    @id @default(cuid())

  // Relaciones
  employeeId       String
  employee         Participant @relation("FeedbackDeliveryEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  cycleId          String
  cycle            PerformanceCycle @relation("FeedbackDeliveryCycle", fields: [cycleId], references: [id], onDelete: Cascade)

  // Token acceso reporte
  reportToken      String    @unique

  // Timestamps
  sentAt           DateTime
  confirmedAt      DateTime?

  // Metadata
  receivedOnTime   Boolean?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("feedback_delivery_confirmations")
  @@index([employeeId])
  @@index([cycleId])
  @@index([reportToken])
}

// ════════════════════════════════════════════════════════════════════════════
// PERFORMANCE RATING CONFIG - Configuración por Cliente
// ════════════════════════════════════════════════════════════════════════════

model PerformanceRatingConfig {
  id          String   @id @default(cuid())
  accountId   String   @unique @map("account_id")

  // Escala: "three_level" | "five_level" | "custom"
  scaleType   String   @default("five_level") @map("scale_type")

  // JSON Array de niveles configurados
  levels      Json     @default("[]")

  // Configuración 9-Box
  enableNineBox           Boolean @default(false) @map("enable_nine_box")
  potentialScaleType      String? @map("potential_scale_type")
  potentialLevels         Json?   @map("potential_levels")

  // Configuración Calibración
  enableCalibration       Boolean @default(false) @map("enable_calibration")
  forcedDistribution      Boolean @default(false) @map("forced_distribution")
  distributionTargets     Json?   @map("distribution_targets")
  requireAdjustmentReason Boolean @default(true) @map("require_adjustment_reason")

  // Configuración PDPs
  autoGeneratePDP         Boolean @default(true) @map("auto_generate_pdp")
  pdpTemplateId           String? @map("pdp_template_id")

  // ═══════════════════════════════════════════════════════════════════════
  // PONDERACIÓN DE EVALUADORES (Nivel 1: Config Cliente)
  // ═══════════════════════════════════════════════════════════════════════
  // JSON: {self: 15, manager: 40, peer: 30, upward: 15} - debe sumar 100
  // Si null, usa default FocalizaHR (25/25/25/25)
  evaluatorWeights        Json?   @map("evaluator_weights")

  // Metadata
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("performance_rating_configs")
}

// ════════════════════════════════════════════════════════════════════════════
// PERFORMANCE RATING - Rating Individual por Empleado por Ciclo
// ════════════════════════════════════════════════════════════════════════════

model PerformanceRating {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  cycleId     String   @map("cycle_id")
  employeeId  String   @map("employee_id")

  // Scores calculados (automático)
  calculatedScore       Float    @map("calculated_score")
  calculatedLevel       String   @map("calculated_level")
  calculatedAt          DateTime @default(now()) @map("calculated_at")

  // Breakdown por tipo evaluador
  selfScore             Float?   @map("self_score")
  managerScore          Float?   @map("manager_score")
  peerAvgScore          Float?   @map("peer_avg_score")
  upwardAvgScore        Float?   @map("upward_avg_score")

  // Completeness
  evaluationCompleteness Float?  @map("evaluation_completeness")
  totalEvaluations      Int?     @map("total_evaluations")
  completedEvaluations  Int?     @map("completed_evaluations")

  // Rating final (después de calibración)
  finalScore            Float?   @map("final_score")
  finalLevel            String?  @map("final_level")

  // Calibración metadata
  calibrated            Boolean  @default(false)
  calibratedAt          DateTime? @map("calibrated_at")
  calibratedBy          String?  @map("calibrated_by")
  calibrationSessionId  String?  @map("calibration_session_id")
  adjustmentReason      String?  @map("adjustment_reason") @db.Text
  adjustmentType        String?  @map("adjustment_type")

  // 9-Box: Potential Rating
  potentialScore        Float?   @map("potential_score")
  potentialLevel        String?  @map("potential_level")
  potentialRatedBy      String?  @map("potential_rated_by")
  potentialRatedAt      DateTime? @map("potential_rated_at")
  potentialNotes        String?  @map("potential_notes") @db.Text
  nineBoxPosition       String?  @map("nine_box_position")

  // Factores AAE (Aspiración, Ability, Engagement) - campos separados para queries de inteligencia
  potentialAspiration   Int?     @map("potential_aspiration")   // 1, 2 o 3
  potentialAbility      Int?     @map("potential_ability")      // 1, 2 o 3
  potentialEngagement   Int?     @map("potential_engagement")   // 1, 2 o 3

  // ════════════════════════════════════════════════════════════════════════════
  // ROLE FIT (Calculado post-360, persistido para reportes)
  // ════════════════════════════════════════════════════════════════════════════
  roleFitScore          Float?    @map("role_fit_score")
  roleFitLevel          String?   @map("role_fit_level")       // OPTIMAL|SOLID|DEVELOPING|GAP|RISK
  roleFitCalculatedAt   DateTime? @map("role_fit_calculated_at")

  // ════════════════════════════════════════════════════════════════════════════
  // HYBRID SCORE: Competencias + Metas ponderado
  // ════════════════════════════════════════════════════════════════════════════
  goalsScore            Float?    @map("goals_score")            // Score metas normalizado (1-5)
  goalsRawPercent       Float?    @map("goals_raw_percent")      // Porcentaje original (0-100)
  goalsCount            Int?      @map("goals_count")            // Cantidad de metas evaluadas
  hybridScore           Float?    @map("hybrid_score")           // Competencias + Metas ponderado

  // ════════════════════════════════════════════════════════════════════════════
  // MATRICES DE TALENTO (Calculadas post-AAE desde Role Fit + AAE)
  // ════════════════════════════════════════════════════════════════════════════
  mobilityQuadrant      String?   @map("mobility_quadrant")    // SUCESOR_NATURAL|EXPERTO_ANCLA|AMBICIOSO_PREMATURO|EN_DESARROLLO
  riskQuadrant          String?   @map("risk_quadrant")        // MOTOR_EQUIPO|FUGA_CEREBROS|BURNOUT_RISK|BAJO_RENDIMIENTO
  riskAlertLevel        String?   @map("risk_alert_level")     // GREEN|YELLOW|ORANGE|RED
  talentAnalyzedAt      DateTime? @map("talent_analyzed_at")

  // ════════════════════════════════════════════════════════════════════════════
  // TENDENCIA DE CUADRANTES (Para detectar transiciones entre ciclos)
  // ════════════════════════════════════════════════════════════════════════════
  previousRiskQuadrant      String?   @map("previous_risk_quadrant")
  previousMobilityQuadrant  String?   @map("previous_mobility_quadrant")
  riskQuadrantChangedAt     DateTime? @map("risk_quadrant_changed_at")
  quadrantTrend             String?   @map("quadrant_trend")             // IMPROVING | STABLE | DECLINING | NEW

  // Succession Readiness
  successionReadiness   String?  @map("succession_readiness")
  targetRoles           Json?    @map("target_roles")
  successionNotes       String?  @map("succession_notes") @db.Text

  // PDP Link
  pdpId                 String?  @map("pdp_id")
  pdpGeneratedAt        DateTime? @map("pdp_generated_at")

  // Metadata
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  account     Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cycle       PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Relación inversa calibración
  calibrationAdjustments CalibrationAdjustment[]

  @@unique([cycleId, employeeId], map: "unique_rating_per_cycle_employee")
  @@index([accountId, cycleId], map: "idx_ratings_account_cycle")
  @@index([finalLevel], map: "idx_ratings_final_level")
  @@index([nineBoxPosition], map: "idx_ratings_nine_box")
  @@index([calibrated], map: "idx_ratings_calibrated")
  @@index([employeeId], map: "idx_ratings_employee")
  @@map("performance_ratings")
}

// ════════════════════════════════════════════════════════════════════════════
// CALIBRATION SESSION - Sesión de calibración grupal v2
// ════════════════════════════════════════════════════════════════════════════

enum CalibrationStatus {
  DRAFT        // Creada pero no iniciada
  IN_PROGRESS  // Sesión activa
  CLOSED       // Cerrada, ratings finales aplicados
  CANCELLED    // Cancelada
}

enum CalibrationRole {
  FACILITATOR   // HR que conduce la sesión (puede ajustar + cerrar)
  REVIEWER      // Gerente/experto que revisa y opina (PUEDE ajustar)
  OBSERVER      // Solo observa, NO puede ajustar
}

model CalibrationSession {
  id                String    @id @default(cuid())

  // Relaciones multi-tenant
  accountId         String    @map("account_id")
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cycleId           String    @map("cycle_id")
  cycle             PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  // Info básica
  name              String              // "Calibración Q4 2025 - Comercial"
  description       String?   @db.Text // Notas/objetivo de la sesión

  // Estado
  status            CalibrationStatus   @default(DRAFT)

  // Fechas
  scheduledAt       DateTime? @map("scheduled_at") // Fecha programada reunión
  startedAt         DateTime? @map("started_at")   // Cuándo inició realmente
  closedAt          DateTime? @map("closed_at")    // Cuándo se cerró

  // Configuración - Distribución Forzada (Curva de Bell)
  enableForcedDistribution  Boolean @default(false) @map("enable_forced_distribution")
  distributionTargets       Json?   @map("distribution_targets")
  // Ejemplo: {"exceptional": 10, "exceeds": 20, "meets": 40, "developing": 20, "needs_improvement": 10}

  // Scope (si vacío = cross-departamental toda la empresa)
  departmentIds     String[]  @default([]) @map("department_ids")

  // Multi-criterio v3.1+ (TASK 17A) - departmentIds se mantiene para backward compat
  filterMode        String    @default("jobLevel") @map("filter_mode")
  filterConfig      Json?     @map("filter_config")

  // Facilitador principal
  facilitatorId     String?   @map("facilitator_id") // Email de quien conduce

  // Audit PDF
  auditPdfUrl       String?   @map("audit_pdf_url") // URL del PDF de auditoría en Storage

  // Audit
  createdBy         String    @map("created_by")  // Email de quien creó
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relaciones
  participants      CalibrationParticipant[]
  adjustments       CalibrationAdjustment[]

  @@index([accountId])
  @@index([cycleId])
  @@index([status])
  @@index([accountId, cycleId])
  @@map("calibration_sessions")
}

// ════════════════════════════════════════════════════════════════════════════
// CALIBRATION PARTICIPANT - Participantes de la sesión
// IMPORTANTE: Roles son TEMPORALES y específicos a ESTA sesión
// Una misma persona puede tener roles diferentes en sesiones diferentes
// ════════════════════════════════════════════════════════════════════════════

model CalibrationParticipant {
  id              String    @id @default(cuid())

  sessionId       String    @map("session_id")
  session         CalibrationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Participante
  participantEmail String   @map("participant_email") // Email del participante
  participantName  String   @map("participant_name")  // Nombre para display
  role             CalibrationRole   @default(REVIEWER)

  // Estado
  invitedAt       DateTime  @default(now()) @map("invited_at")
  acceptedAt      DateTime? @map("accepted_at")

  // Constraint: una persona solo una vez por sesión
  @@unique([sessionId, participantEmail])
  @@index([sessionId])
  @@index([participantEmail]) // Para encontrar sesiones de un usuario
  @@map("calibration_participants")
}

// ════════════════════════════════════════════════════════════════════════════
// CALIBRATION ADJUSTMENT - Ajustes realizados durante calibración
// ════════════════════════════════════════════════════════════════════════════

model CalibrationAdjustment {
  id              String    @id @default(cuid())

  sessionId       String    @map("session_id")
  session         CalibrationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  ratingId        String    @map("rating_id") // PerformanceRating que se ajustó
  rating          PerformanceRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  // Snapshot de valores ANTERIORES (antes del ajuste)
  previousFinalScore      Float?  @map("previous_final_score")
  previousFinalLevel      String? @map("previous_final_level")
  previousPotentialScore  Float?  @map("previous_potential_score")
  previousPotentialLevel  String? @map("previous_potential_level")
  previousNineBox         String? @map("previous_nine_box")

  // Valores NUEVOS (después del ajuste)
  newFinalScore         Float?  @map("new_final_score")
  newFinalLevel         String? @map("new_final_level")
  newPotentialScore     Float?  @map("new_potential_score")
  newPotentialLevel     String? @map("new_potential_level")
  newNineBox            String? @map("new_nine_box")

  // Justificación (OBLIGATORIA - mínimo 10 caracteres)
  justification   String    @db.Text

  // Estado transitorio: PENDING → APPLIED | CANCELLED
  status          String    @default("PENDING") // PENDING | APPLIED | CANCELLED
  appliedAt       DateTime? @map("applied_at")  // Cuándo se aplicó al cerrar sesión

  // Audit
  adjustedBy      String    @map("adjusted_by")  // Email de quien ajustó
  adjustedAt      DateTime  @default(now()) @map("adjusted_at")

  @@index([sessionId])
  @@index([ratingId])
  @@index([adjustedBy]) // Para audit trail por usuario
  @@index([status])     // Para queries de PENDING en cierre
  @@map("calibration_adjustments")
}

// ════════════════════════════════════════════════════════════════════════════
// MÓDULO PDI (PLAN DE DESARROLLO INDIVIDUAL)
// Permite crear planes de desarrollo desde Gap Analysis del 360°
// ════════════════════════════════════════════════════════════════════════════

// ────────────────────────────────────────────────────────────────────────────
// PLAN DE DESARROLLO (Cabecera)
// ────────────────────────────────────────────────────────────────────────────

model DevelopmentPlan {
  id                String   @id @default(cuid())
  accountId         String
  employeeId        String
  managerId         String
  cycleId           String

  status            DevelopmentPlanStatus @default(DRAFT)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agreedAt          DateTime?
  completedAt       DateTime?

  validFrom         DateTime  @default(now())
  validUntil        DateTime?

  originGapAnalysis Json?
  aiSuggestionsUsed Boolean  @default(false)

  account           Account  @relation(fields: [accountId], references: [id])
  employee          Employee @relation("EmployeePDI", fields: [employeeId], references: [id])
  manager           Employee @relation("ManagerPDI", fields: [managerId], references: [id])
  cycle             PerformanceCycle @relation(fields: [cycleId], references: [id])

  goals             DevelopmentGoal[]
  checkIns          PDICheckIn[]

  // Sucesion Inteligente
  successionCandidate SuccessionCandidate?

  @@unique([employeeId, cycleId])
  @@index([accountId])
  @@index([managerId])
  @@index([status])
  @@map("development_plans")
}

enum DevelopmentPlanStatus {
  DRAFT
  PENDING_REVIEW
  AGREED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ────────────────────────────────────────────────────────────────────────────
// OBJETIVO DE DESARROLLO (Detalle)
// ────────────────────────────────────────────────────────────────────────────

model DevelopmentGoal {
  id                String   @id @default(cuid())
  planId            String

  competencyCode    String
  competencyName    String
  originalGap       Float?
  gapType           DevelopmentGapType?

  title             String
  description       String?  @db.Text
  targetOutcome     String
  measurementCriteria String?

  priority          DevelopmentPriority @default(MEDIA)
  category          DevelopmentCategory @default(SKILL_DEVELOPMENT)

  startDate         DateTime  @default(now())
  targetDate        DateTime

  progressPercent   Int       @default(0)
  status            DevelopmentGoalStatus @default(NOT_STARTED)

  suggestedResources Json?
  action            String?  @db.Text

  linkedBusinessGoalId String?

  aiGenerated       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  completedAt       DateTime?

  plan              DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Metas (Business Goals Engine) - link inverso
  linkedBusinessGoal Goal?

  @@index([planId])
  @@index([competencyCode])
  @@index([status])
  @@map("development_goals")
}

enum DevelopmentGapType {
  BLIND_SPOT
  HIDDEN_STRENGTH
  DEVELOPMENT_AREA
  PEER_DISCONNECT
}

enum DevelopmentPriority {
  ALTA
  MEDIA
  BAJA
}

enum DevelopmentCategory {
  SKILL_DEVELOPMENT
  BEHAVIORAL_CHANGE
  KNOWLEDGE_ACQUISITION
  EXPERIENCE_BUILDING
  CERTIFICATION
  MENTORING
}

enum DevelopmentGoalStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_TRACK
  AT_RISK
  COMPLETED
  CANCELLED
}

// ────────────────────────────────────────────────────────────────────────────
// CHECK-INS DE SEGUIMIENTO
// ────────────────────────────────────────────────────────────────────────────

model PDICheckIn {
  id                String   @id @default(cuid())
  planId            String

  scheduledDate     DateTime
  completedDate     DateTime?

  status            CheckInStatus @default(SCHEDULED)

  managerNotes      String?  @db.Text
  employeeNotes     String?  @db.Text

  goalProgress      Json?
  actionItems       Json?

  nextCheckInDate   DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  plan              DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([scheduledDate])
  @@map("pdi_check_ins")
}

enum CheckInStatus {
  SCHEDULED
  COMPLETED
  SKIPPED
  RESCHEDULED
}

// ════════════════════════════════════════════════════════════════════════════
// COMPETENCY TARGET - Nivel esperado por cargo (Role Fit)
// ════════════════════════════════════════════════════════════════════════════

model CompetencyTarget {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")

  // Competencia
  competencyCode  String   @map("competency_code")  // CORE-COMM, LEAD-DEV, etc.

  // Cargo (por nivel estándar, no FK — Employee.standardJobLevel)
  standardJobLevel String  @map("standard_job_level")
  // Valores: 'gerente_director' | 'subgerente_subdirector' | 'jefe' |
  //          'supervisor_coordinador' | 'profesional_analista' |
  //          'asistente_otros' | 'operativo_auxiliar'

  // Nivel esperado (null = N/A, no aplica)
  targetScore     Float?   @map("target_score")  // 1.0 - 5.0 o null

  // Auditoría
  isDefault       Boolean  @default(true) @map("is_default")
  ratifiedAt      DateTime? @map("ratified_at")
  ratifiedBy      String?   @map("ratified_by")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relaciones
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, competencyCode, standardJobLevel], map: "unique_target_per_job_level")
  @@index([accountId], map: "idx_comp_targets_account")
  @@index([standardJobLevel], map: "idx_comp_targets_job_level")
  @@map("competency_targets")
}

// ════════════════════════════════════════════════════════════════════════════
// MÓDULO DE ESTRATEGIA Y METAS (BUSINESS GOALS ENGINE) - SOBERANO
// Vive independiente de los ciclos de evaluación
// ════════════════════════════════════════════════════════════════════════════

model Goal {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")

  // ────────────────────────────────────────────────────────────────────────────
  // 1. JERARQUÍA Y CASCADA (The Alignment Tree)
  // ────────────────────────────────────────────────────────────────────────────
  parentId        String?  @map("parent_id")
  parent          Goal?    @relation("GoalCascade", fields: [parentId], references: [id], onDelete: SetNull)
  children        Goal[]   @relation("GoalCascade")

  level           GoalLevel @default(INDIVIDUAL)
  originType      GoalOriginType @map("origin_type")

  // ────────────────────────────────────────────────────────────────────────────
  // 2. PROPIEDAD
  // ────────────────────────────────────────────────────────────────────────────
  employeeId      String?  @map("employee_id")    // Null si es meta de empresa/área
  departmentId    String?  @map("department_id")  // Para metas de área (Nivel 1)
  createdById     String   @map("created_by_id")  // Auditoría de creación

  // ────────────────────────────────────────────────────────────────────────────
  // 3. DEFINICIÓN
  // ────────────────────────────────────────────────────────────────────────────
  title           String
  description     String?  @db.Text
  type            GoalType @default(KPI)

  // ────────────────────────────────────────────────────────────────────────────
  // 4. TIEMPO (Vigencia de Negocio - Independiente de ciclos)
  // ────────────────────────────────────────────────────────────────────────────
  startDate       DateTime @map("start_date")
  dueDate         DateTime @map("due_date")
  periodYear      Int      @map("period_year")  // Ej: 2026
  periodQuarter   Int?     @map("period_quarter") // 1-4 opcional

  // ────────────────────────────────────────────────────────────────────────────
  // 5. MEDICIÓN (Motor Determinista)
  // ────────────────────────────────────────────────────────────────────────────
  metricType      GoalMetricType @default(PERCENTAGE) @map("metric_type")
  startValue      Float    @default(0) @map("start_value")
  targetValue     Float    @default(100) @map("target_value")
  currentValue    Float    @default(0) @map("current_value")
  unit            String?  // Ej: "USD", "%", "Tickets", "Clientes"

  // ────────────────────────────────────────────────────────────────────────────
  // 6. RESULTADOS E INTELIGENCIA
  // ────────────────────────────────────────────────────────────────────────────
  progress        Float    @default(0)  // (Current-Start)/(Target-Start)*100
  status          GoalStatus @default(NOT_STARTED)

  isAligned       Boolean  @default(false) @map("is_aligned")  // True si traza ruta hasta Nivel 0
  isOrphan        Boolean  @default(true)  @map("is_orphan")   // True si no tiene padre y no es Nivel 0

  // ────────────────────────────────────────────────────────────────────────────
  // 7. INTEGRACIÓN PERFORMANCE
  // ────────────────────────────────────────────────────────────────────────────
  weight          Float    @default(0)  // Peso relativo (0-100) para nota final

  // ────────────────────────────────────────────────────────────────────────────
  // 8. CONEXIÓN PDI (opcional)
  // ────────────────────────────────────────────────────────────────────────────
  linkedDevGoalId String?  @unique @map("linked_dev_goal_id")  // Si nació de un DevelopmentGoal

  // ────────────────────────────────────────────────────────────────────────────
  // TIMESTAMPS
  // ────────────────────────────────────────────────────────────────────────────
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")

  // ────────────────────────────────────────────────────────────────────────────
  // RELACIONES
  // ────────────────────────────────────────────────────────────────────────────
  account         Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner           Employee?  @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  linkedDevGoal   DevelopmentGoal? @relation(fields: [linkedDevGoalId], references: [id], onDelete: SetNull)

  progressUpdates GoalProgressUpdate[]
  cascadeRules    GoalCascadeRule[]

  // G4: Meta solo para líderes
  isLeaderGoal    Boolean  @default(false) @map("is_leader_goal")

  // ────────────────────────────────────────────────────────────────────────────
  // CIERRE DE META (Flujo de aprobación)
  // ────────────────────────────────────────────────────────────────────────────
  closureRequestedAt  DateTime? @map("closure_requested_at")
  closureRequestedBy  String?   @map("closure_requested_by")
  closedAt            DateTime? @map("closed_at")
  closedBy            String?   @map("closed_by")
  closureApprovedBy   String?   @map("closure_approved_by")
  closureNotes        String?   @map("closure_notes")

  // ────────────────────────────────────────────────────────────────────────────
  // ÍNDICES
  // ────────────────────────────────────────────────────────────────────────────
  @@index([accountId])
  @@index([parentId])
  @@index([employeeId])
  @@index([departmentId])
  @@index([level])
  @@index([status])
  @@index([periodYear])
  @@index([dueDate])
  @@map("goals")
}

// ────────────────────────────────────────────────────────────────────────────
// TIME TRAVEL: Historial para reconstruir estado en fecha pasada
// ────────────────────────────────────────────────────────────────────────────

model GoalProgressUpdate {
  id               String   @id @default(cuid())
  goalId           String   @map("goal_id")
  accountId        String   @map("account_id")

  // Snapshot del cambio
  previousValue    Float    @map("previous_value")
  newValue         Float    @map("new_value")
  previousProgress Float    @map("previous_progress")
  newProgress      Float    @map("new_progress")

  // Contexto
  comment          String?  @db.Text
  evidence         String?  // URL o referencia a evidencia

  // Auditoría
  updatedById      String   @map("updated_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relaciones
  goal             Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([accountId])
  @@index([createdAt])  // VITAL para queries de rango de fecha (Time Travel)
  @@map("goal_progress_updates")
}

// ────────────────────────────────────────────────────────────────────────────
// BANCO DE TEMPLATES (Evita "Síndrome Hoja en Blanco")
// ────────────────────────────────────────────────────────────────────────────

model GoalLibrary {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")

  title           String
  description     String?  @db.Text
  category        String   // "Ventas", "Operaciones", "Liderazgo", "Finanzas"

  // Template de medición
  metricType      GoalMetricType @default(PERCENTAGE) @map("metric_type")
  suggestedTarget Float?   @map("suggested_target")
  unit            String?

  // Metadata
  isActive        Boolean  @default(true) @map("is_active")
  usageCount      Int      @default(0) @map("usage_count")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([category])
  @@map("goal_library")
}

// ════════════════════════════════════════════════════════════════════════════
// G1: CONFIGURACIÓN DE ELEGIBILIDAD POR NIVEL DE CARGO
// ════════════════════════════════════════════════════════════════════════════

model GoalJobConfig {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  standardJobLevel   String   @map("standard_job_level")
  hasGoals           Boolean  @default(false) @map("has_goals")
  goalGroupId        String?  @map("goal_group_id")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  account            Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  goalGroup          GoalGroup? @relation(fields: [goalGroupId], references: [id])

  @@unique([accountId, standardJobLevel])
  @@map("goal_job_configs")
}

// ════════════════════════════════════════════════════════════════════════════
// G2: GRUPOS DE PONDERACIÓN
// ════════════════════════════════════════════════════════════════════════════

model GoalGroup {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")

  name            String
  code            String

  weightBusiness  Float    @default(0) @map("weight_business")
  weightLeader    Float    @default(0) @map("weight_leader")
  weightNPS       Float    @default(0) @map("weight_nps")
  weightSpecific  Float    @default(0) @map("weight_specific")

  isActive        Boolean  @default(true) @map("is_active")
  isDefault       Boolean  @default(false) @map("is_default")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account         Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  jobConfigs      GoalJobConfig[]
  cascadeRules    GoalCascadeRule[]

  @@unique([accountId, code])
  @@map("goal_groups")
}

// ════════════════════════════════════════════════════════════════════════════
// G3: REGLAS DE CASCADA AUTOMÁTICA
// ════════════════════════════════════════════════════════════════════════════

model GoalCascadeRule {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")

  name            String
  description     String?

  sourceGoalId    String   @map("source_goal_id")
  targetGroupId   String?  @map("target_group_id")

  assignedWeight  Float    @default(0) @map("assigned_weight")
  isLeaderOnly    Boolean  @default(false) @map("is_leader_only")

  isActive        Boolean  @default(true) @map("is_active")
  lastExecutedAt  DateTime? @map("last_executed_at")
  lastExecutedBy  String?  @map("last_executed_by")
  executionCount  Int      @default(0) @map("execution_count")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account         Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceGoal      Goal       @relation(fields: [sourceGoalId], references: [id])
  targetGroup     GoalGroup? @relation(fields: [targetGroupId], references: [id])

  @@map("goal_cascade_rules")
}

// ────────────────────────────────────────────────────────────────────────────
// ENUMS - METAS
// ────────────────────────────────────────────────────────────────────────────

enum GoalLevel {
  COMPANY      // Nivel 0 - Metas corporativas
  AREA         // Nivel 1 - Metas de gerencia/departamento
  INDIVIDUAL   // Nivel 2 - Metas de empleado
}

enum GoalOriginType {
  STRATEGIC_CASCADE   // Viene de arriba (cascadeo)
  MANAGER_CREATED     // Nace localmente (jefe crea)
}

enum GoalType {
  KPI           // Meta numérica simple
  OBJECTIVE     // El "O" de OKR (contenedor)
  KEY_RESULT    // El "KR" de OKR (medible)
  PROJECT       // Hito binario (completado/no completado)
}

enum GoalMetricType {
  PERCENTAGE    // 0-100%
  CURRENCY      // Dinero (USD, CLP, etc)
  NUMBER        // Cantidad absoluta
  BINARY        // 0 o 100 (completado/no)
}

enum GoalStatus {
  NOT_STARTED      // Sin iniciar
  ON_TRACK         // En tiempo
  AT_RISK          // En riesgo
  BEHIND           // Atrasado
  PENDING_CLOSURE  // Pendiente de aprobación de cierre
  COMPLETED        // Completado
  CANCELLED        // Cancelado
}

// ════════════════════════════════════════════════════════════════════════════
// SUCESION INTELIGENTE - Enums
// ════════════════════════════════════════════════════════════════════════════

enum BenchStrengthLevel {
  STRONG    // 2+ Ready Now
  MODERATE  // 1 Ready Now + 2+ Ready 1-2 anios
  WEAK      // Solo Ready 1-2 anios, sin Ready Now
  NONE      // Sin candidatos viables
  UNKNOWN   // No calculado aun
}

enum ReadinessLevel {
  READY_NOW
  READY_1_2_YEARS
  READY_3_PLUS
  NOT_VIABLE
}

enum CandidateStatus {
  ACTIVE        // Candidato vigente
  PROMOTED      // Fue promovido a este rol
  WITHDRAWN     // Retirado de consideracion
  DISQUALIFIED  // Ya no cumple umbral 75% o Aspiracion cayo a 1
}

// ════════════════════════════════════════════════════════════════════════════
// POSICION CRITICA (El cargo que necesita sucesor)
// ════════════════════════════════════════════════════════════════════════════

model CriticalPosition {
  id                String   @id @default(cuid())
  accountId         String   @map("account_id")

  // Identificacion del rol
  positionTitle     String   @map("position_title")
  standardJobLevel  String   @map("standard_job_level")
  departmentId      String?  @map("department_id")

  // Incumbent actual (puede ser null si vacante)
  incumbentId       String?  @map("incumbent_id")

  // Bench Strength (calculado automaticamente)
  benchStrength         BenchStrengthLevel @default(UNKNOWN) @map("bench_strength")
  benchCalculatedAt     DateTime?          @map("bench_calculated_at")

  // Flight Risk del Incumbent (de TalentIntelligence)
  incumbentFlightRisk       String?    @map("incumbent_flight_risk")
  incumbentRetirementDate   DateTime?  @map("incumbent_retirement_date")

  // Auditoria
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  isActive          Boolean  @default(true) @map("is_active")

  // Relaciones
  account           Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  incumbent         Employee?   @relation("PositionIncumbent", fields: [incumbentId], references: [id])
  department        Department? @relation(fields: [departmentId], references: [id])
  candidates        SuccessionCandidate[]

  @@unique([accountId, positionTitle, departmentId], map: "unique_position_per_dept")
  @@index([accountId], map: "idx_critical_pos_account")
  @@index([benchStrength], map: "idx_critical_pos_bench")
  @@index([incumbentFlightRisk], map: "idx_critical_pos_flight_risk")
  @@index([incumbentId], map: "idx_critical_pos_incumbent")
  @@index([departmentId], map: "idx_critical_pos_department")
  @@map("critical_positions")
}

// ════════════════════════════════════════════════════════════════════════════
// CANDIDATO A SUCESION (La nominacion)
// ════════════════════════════════════════════════════════════════════════════

model SuccessionCandidate {
  id                  String   @id @default(cuid())
  accountId           String   @map("account_id")

  // Relacion Posicion <-> Candidato
  criticalPositionId  String   @map("critical_position_id")
  employeeId          String   @map("employee_id")

  // Filtro inicial (snapshot al momento de nominar)
  currentRoleFit      Float    @map("current_role_fit")
  passedThreshold     Boolean  @map("passed_threshold")
  nineBoxPosition     String?  @map("nine_box_position")
  aspirationLevel     Int?     @map("aspiration_level")

  // Match vs Target (calculado)
  matchPercent        Float    @map("match_percent")
  gapsJson            Json     @map("gaps_json")
  gapsCriticalCount   Int      @map("gaps_critical_count")
  gapsStrategicCount  Int      @map("gaps_strategic_count")
  gapsLeadershipCount Int      @map("gaps_leadership_count")

  // Readiness (calculado por algoritmo)
  readinessLevel      ReadinessLevel @map("readiness_level")
  readinessScore      Float          @map("readiness_score")
  readinessReasoning  Json           @map("readiness_reasoning")
  estimatedMonths     Int?           @map("estimated_months")

  // Override humano (con accountability)
  readinessOverride   ReadinessLevel? @map("readiness_override")
  overrideReason      String?         @map("override_reason") @db.Text
  overrideBy          String?         @map("override_by")
  overrideAt          DateTime?       @map("override_at")

  // Contexto adicional
  flightRisk          String?  @map("flight_risk")

  // AAE Snapshot
  ability             Int?
  engagement          Int?

  // Link a PDI
  developmentPlanId   String?  @unique @map("development_plan_id")

  // Estado y auditoria
  status              CandidateStatus @default(ACTIVE)
  nominatedBy         String          @map("nominated_by")
  nominatedAt         DateTime        @default(now()) @map("nominated_at")
  lastCalculatedAt    DateTime        @default(now()) @map("last_calculated_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  // Relaciones
  account             Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  criticalPosition    CriticalPosition @relation(fields: [criticalPositionId], references: [id], onDelete: Cascade)
  employee            Employee         @relation("SuccessionCandidateEmployee", fields: [employeeId], references: [id])
  developmentPlan     DevelopmentPlan? @relation(fields: [developmentPlanId], references: [id])
  backfillPlan        SuccessionBackfillPlan?

  @@unique([criticalPositionId, employeeId], map: "unique_candidate_per_position")
  @@index([accountId], map: "idx_succ_cand_account")
  @@index([readinessLevel], map: "idx_succ_cand_readiness")
  @@index([status], map: "idx_succ_cand_status")
  @@index([flightRisk], map: "idx_succ_cand_flight_risk")
  @@index([matchPercent], map: "idx_succ_cand_match")
  @@index([criticalPositionId], map: "idx_succ_cand_position")
  @@index([employeeId], map: "idx_succ_cand_employee")
  @@map("succession_candidates")
}

// ════════════════════════════════════════════════════════════════════════════
// PLAN DE BACKFILL (Efecto Dominó — planificación de cobertura post-nominación)
// ════════════════════════════════════════════════════════════════════════════

model SuccessionBackfillPlan {
  id                   String    @id @default(cuid())
  accountId            String    @map("account_id")

  // Una nominación genera máximo un plan de backfill
  sourceCandidateId    String    @unique @map("source_candidate_id")

  // Snapshot del cargo que quedaría vacante
  vacatedPositionTitle String    @map("vacated_position_title")
  vacatedPositionId    String?   @map("vacated_position_id")
  vacatedDepartmentId  String?   @map("vacated_department_id")

  // PENDING | COVERED | EXTERNAL_SEARCH | POSITION_ELIMINATED
  resolution           String    @default("PENDING")

  // Si COVERED
  backfillEmployeeId   String?   @map("backfill_employee_id")
  backfillEmployeeName String?   @map("backfill_employee_name")

  // Si EXTERNAL_SEARCH
  externalReason       String?   @db.Text @map("external_reason")

  // Auditoría
  resolvedAt           DateTime? @map("resolved_at")
  resolvedBy           String?   @map("resolved_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  account              Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceCandidate      SuccessionCandidate  @relation(fields: [sourceCandidateId], references: [id], onDelete: Cascade)
  backfillEmployee     Employee?            @relation("BackfillEmployee", fields: [backfillEmployeeId], references: [id])
  vacatedDepartment    Department?          @relation(fields: [vacatedDepartmentId], references: [id])

  @@index([accountId])
  @@index([resolution])
  @@index([vacatedDepartmentId])
  @@index([backfillEmployeeId], map: "idx_backfill_employee")
  @@map("succession_backfill_plans")
}
